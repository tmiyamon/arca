import go.fmt
import go.net.http

fun handleHello(w: http.ResponseWriter, r: *http.Request) {
  fmt.Fprintf(w, "Hello from Arca!")
}

fun handleHealth(w: http.ResponseWriter, r: *http.Request) {
  fmt.Fprintf(w, "ok")
}

fun main() {
  http.HandleFunc("/", handleHello)
  http.HandleFunc("/health", handleHealth)
  fmt.Println("Listening on :8080")
  http.ListenAndServe(":8080", nil)
}

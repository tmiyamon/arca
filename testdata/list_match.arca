import go.fmt

fn describe(items: List[String]) -> String {
  match items {
    [] -> "empty"
    [first, ..rest] -> "first: ${first}"
  }
}

fn main() {
  fmt.Println(describe([]))
  fmt.Println(describe(["hello", "world"]))
  let extended = [0, ..nums()]
  fmt.Println(extended)
}

fn nums() -> List[Int] {
  [1, 2, 3]
}

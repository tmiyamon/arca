// Slice E1+E2: literal hint coercion. The literal types itself to the
// surrounding context's narrow type when the value fits.
//
// Slice E4: arithmetic on Int / UInt routes through panic-checked
// helpers (`__addInt`, `__subUInt`, `__mulInt`, ...). Float arithmetic
// stays plain (Inf is in spec, no panic).

fun safeAdd(a: Int, b: Int) -> Int { a + b }
fun safeSub(a: UInt, b: UInt) -> UInt { a - b }
fun safeMul(a: Int, b: Int) -> Int { a * b }

fun mixFloat(a: Float, b: Float) -> Float { a + b }

type Sample {
  Sample(small: Int8, big: UInt32, ratio: Float32)
}

fun makeSample() -> Sample {
  Sample(small: 100, big: 99999, ratio: 3.14)
}

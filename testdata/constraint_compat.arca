import go "fmt"

type Age = Int{min: 0, max: 150}
type AdultAge = Int{min: 18, max: 150}

fun greet(age: Age) -> String {
  "hello"
}

fun main() {
  let r = try {
    let adult = AdultAge(25)?
    greet(adult)
  }
  match r {
    Ok(msg) => fmt.Println(msg)
    Error(err) => fmt.Println(err)
  }
}

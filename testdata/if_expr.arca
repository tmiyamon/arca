import go "fmt"

fun classify(n: Int) -> String {
  if n > 0 {
    "positive"
  } else if n < 0 {
    "negative"
  } else {
    "zero"
  }
}

fun describe(x: Int) -> String {
  if x == 0 {
    "zero"
  } else {
    "nonzero"
  }
}

fun main() {
  fmt.Println(classify(42))
  fmt.Println(classify(-1))
  fmt.Println(classify(0))
  fmt.Println(describe(5))

  let label = if 1 > 0 { "yes" } else { "no" }
  fmt.Println(label)
}

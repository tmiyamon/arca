// User-defined narrow alias via `bits` constraint, distinct from the
// built-in tower type names. Combines with min/max to add a runtime check
// on top of the storage hint.
type Percent = UInt{bits: 8, max: 100}

// Inline `bits` at struct field positions (also distinct names).
type Sample {
  Sample(small: Int{bits: 16}, ratio: Float{bits: 32})
}

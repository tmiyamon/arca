import go.fmt

type User {
  User(name: String, age: Int)

  fn is_adult() -> Bool {
    self.age >= 18
  }

  pub fn to_json() -> String {
    "{\"name\": \"${self.name}\", \"age\": ${self.age}}"
  }

  fn greet(greeting: String) -> String {
    "${greeting}, ${self.name}!"
  }
}

fn main() {
  let user = User(name: "Alice", age: 30)
  fmt.Println(user.is_adult())
  fmt.Println(user.to_json())
  fmt.Println(user.greet("Hello"))
}
